FROM python:3.11-slim

WORKDIR /app

COPY requirements-api.txt .
RUN pip install --no-cache-dir -r requirements-api.txt

COPY *.py ./
COPY agents/ ./agents/
COPY campaign_database.json ./
COPY static/ ./static/

EXPOSE 8080
CMD ["sh", "-c", "echo 'Starting moodlight-api on port ${PORT:-8080}' && exec uvicorn api_server:app --host 0.0.0.0 --port ${PORT:-8080}"]
